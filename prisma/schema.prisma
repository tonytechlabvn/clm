generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Authentication & Users ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  wpId          Int?      @unique
  role          String    @default("user") // "root" | "admin" | "user"
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  orgMemberships      OrgMember[]
  aiQuota             UserAiQuota?
  cmaPlatformAccounts CmaPlatformAccount[]
  cmaPosts            CmaPost[]

  // LMS relations
  instructedCourses    Course[]          @relation("CourseInstructor")
  courseEnrollments     CourseEnrollment[]
  lessonProgress       LessonProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── Organizations ───

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  logoUrl     String?
  isActive    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members             OrgMember[]
  cmaPlatformAccounts CmaPlatformAccount[]
  cmaPosts            CmaPost[]
  cmaTemplates        CmaTemplate[]

  // LMS relations
  courses              Course[]
}

model OrgMember {
  id       String   @id @default(cuid())
  userId   String
  orgId    String
  role     String   @default("member") // "owner" | "admin" | "member"
  joinedAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

// ─── System Config ───

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─── AI Quota & Usage ───

model UserAiQuota {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  freeUsesLeft Int       @default(0)
  paidUsesLeft Int       @default(0)
  totalUsed    Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model AiUsageLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  source    String // "pool" | "byok"
  provider  String?
  model     String?
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

// ─── CMA: Content Marketing Automation ───

model CmaPlatformAccount {
  id           String    @id @default(cuid())
  orgId        String
  userId       String // who connected this account
  platform     String // "wordpress" | "facebook" | "linkedin"
  label        String // user-friendly name e.g. "tonytechlab.com"
  siteUrl      String? // WordPress site URL
  username     String? // WordPress username
  accessToken  String    @db.Text // encrypted Application Password or OAuth token
  refreshToken String?   @db.Text // encrypted, for OAuth platforms
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org   Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts CmaPostPlatform[]

  @@index([orgId])
  @@index([userId])
}

model CmaPost {
  id            String    @id @default(cuid())
  orgId         String
  authorId      String
  title         String
  slug          String?
  content       String    @db.Text // markdown source
  excerpt       String?   @db.Text
  featuredImage String? // local path or URL
  categories    String[] // synced with WP taxonomy
  tags          String[] // synced with WP taxonomy
  status        String    @default("draft") // "draft" | "pending_review" | "approved" | "scheduled" | "publishing" | "published" | "failed"
  publishError  String?   @db.Text
  scheduledAt   DateTime?
  publishedAt   DateTime?
  pgBossJobId   String? // pg-boss job ID for cancellation on reschedule
  // Phase 4: AI curation fields
  aiGenerated       Boolean   @default(false)
  sourceUrl         String?   @db.Text // original article URL for curated content
  normalizedSourceUrl String? @db.Text // URL stripped of tracking params for dedup
  parentPostId      String? // parent blog post ID for social excerpt children
  // Phase 5: AI generation fields
  outlineData       Json? // approved outline structure for reference
  originalAiDraft   String?   @db.Text // original AI output before human edits
  generationStatus  String? // "outline_approved" | "generating" | "generated" | "generation_failed"
  // Phase 7: Block editor & template fields
  contentFormat  String   @default("markdown") // "markdown" | "blocks"
  templateId     String?                       // FK to CmaTemplate
  styleTheme     String   @default("default")  // theme for styled publishing
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  org       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author    User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  platforms CmaPostPlatform[]
  media     CmaMedia[]
  parent    CmaPost?            @relation("PostChildren", fields: [parentPostId], references: [id], onDelete: SetNull)
  children  CmaPost[]           @relation("PostChildren")
  metrics   CmaPostMetrics?
  snapshots CmaMetricsSnapshot[]
  template  CmaTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([authorId])
  @@index([status])
  @@index([scheduledAt])
  @@index([normalizedSourceUrl])
}

// Tracks per-platform publish state for a post
model CmaPostPlatform {
  id             String    @id @default(cuid())
  postId         String
  accountId      String
  platformPostId String? // external ID on the platform
  platformUrl    String? // URL on the platform
  status         String    @default("pending") // "pending" | "publishing" | "published" | "failed"
  publishError   String?   @db.Text
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  post    CmaPost            @relation(fields: [postId], references: [id], onDelete: Cascade)
  account CmaPlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([postId, accountId])
  @@index([postId])
  @@index([accountId])
}

// Media files uploaded for CMA posts
model CmaMedia {
  id           String   @id @default(cuid())
  orgId        String
  postId       String?
  fileName     String // UUID-based filename
  originalName String // original upload name (for display)
  mimeType     String
  size         Int // bytes
  localPath    String // path on disk
  wpMediaId    Int? // WordPress attachment ID after upload
  // Phase 7: Image source tracking
  source      String  @default("upload") // "upload" | "unsplash" | "ai-generated"
  sourceUrl   String? // Unsplash photo URL for attribution
  aiPrompt    String? @db.Text // prompt used for AI generation
  aiProvider  String? // "openai" | "google"
  createdAt    DateTime @default(now())

  post CmaPost? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([postId])
}

// ─── CMA: RSS Feed Management (Phase 4) ───

model CmaRssFeed {
  id            String    @id @default(cuid())
  orgId         String
  name          String
  url           String
  keywords      String[] // keyword filters for article matching
  language      String    @default("en")
  fetchFrequency String   @default("daily") // "hourly" | "every_6h" | "daily"
  isActive      Boolean   @default(true)
  lastFetchedAt DateTime?
  errorCount    Int       @default(0) // consecutive fetch failures
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([orgId])
  @@index([isActive])
}

// ─── CMA: AI Usage Budget Tracking (Phase 4-5) ───

model CmaAiUsage {
  id         String @id @default(cuid())
  orgId      String
  month      String // "2026-04" format
  tokensUsed Int    @default(0)
  tokenLimit Int    @default(1000000) // configurable per org

  @@unique([orgId, month])
  @@index([orgId])
}

// ─── CMA: Daily AI Image Usage Rate Limiting ───

model CmaAiImageUsage {
  id         String   @id @default(cuid())
  orgId      String
  date       String   // "YYYY-MM-DD" for daily bucketing
  imageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([orgId, date])
  @@index([orgId])
}

// ─── CMA: Content Templates ───

model CmaTemplate {
  id          String   @id @default(cuid())
  orgId       String?  // null = system-level template
  name        String
  slug        String   @unique
  description String?  @db.Text
  category    String   // "tutorial" | "news" | "announce"
  thumbnail   String?
  blocks      Json     // BlockNote JSON block array
  styleTheme  String   @default("default")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org   Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  posts CmaPost[]

  @@index([orgId])
  @@index([category])
}

// ─── CMA: Post Metrics (Phase 6) ───

model CmaPostMetrics {
  id                String    @id @default(cuid())
  postId            String    @unique
  reach             Int       @default(0)
  impressions       Int       @default(0)
  clicks            Int       @default(0)
  likes             Int       @default(0)
  shares            Int       @default(0)
  comments          Int       @default(0)
  pageViews         Int       @default(0)
  lastMetricsSyncAt DateTime?
  updatedAt         DateTime  @updatedAt

  post CmaPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// Daily metrics snapshot for time-series charts (Phase 6)
model CmaMetricsSnapshot {
  id          String   @id @default(cuid())
  postId      String
  date        DateTime @db.Date // snapshot date
  reach       Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  likes       Int      @default(0)
  shares      Int      @default(0)
  comments    Int      @default(0)

  post CmaPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, date])
  @@index([postId])
  @@index([date])
}

// ─── CLM: Core Learning Management ───

model Course {
  id             String   @id @default(cuid())
  orgId          String
  instructorId   String
  title          String
  slug           String   @unique
  description    String?  @db.Text
  thumbnailUrl   String?
  level          String   @default("beginner") // "beginner" | "intermediate" | "advanced"
  status         String   @default("draft") // "draft" | "published" | "archived"
  estimatedHours Float?
  tags           String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org          Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  instructor   User               @relation("CourseInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  sections     Section[]
  enrollments  CourseEnrollment[]

  @@index([orgId])
  @@index([instructorId])
  @@index([status])
}

model Section {
  id          String   @id @default(cuid())
  courseId     String
  title       String
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id               String   @id @default(cuid())
  sectionId        String
  title            String
  type             String   @default("text") // "text" | "video" | "code" | "quiz"
  content          String?  @db.Text // markdown content
  videoUrl         String?
  order            Int      @default(0)
  estimatedMinutes Int?
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  section  Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([sectionId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  lessonId    String
  userId      String
  status      String    @default("not_started") // "not_started" | "in_progress" | "completed"
  completedAt DateTime?
  timeSpent   Int       @default(0) // seconds
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId])
  @@index([userId])
}

model CourseEnrollment {
  id          String    @id @default(cuid())
  courseId     String
  userId      String
  progress    Float     @default(0) // 0-100 percentage
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
}
