{
  "name": "@tonytechlab/clm-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for publishing markdown content to CLM → WordPress",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clm-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "wordpress",
    "clm",
    "content-management"
  ],
  "author": "Tony Tech Lab <tony.nguyen@tonytechlab.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tonytechlab/clm.git",
    "directory": "clm-mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
